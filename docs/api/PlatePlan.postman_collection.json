              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "recipes",
                "{{recipeId}}",
                "nutrition-analysis"
              ]
            }
          }
        },
        {
          "name": "Meal Plan Diet Suggestions",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/meal-plans/{{mealPlanId}}/diet-suggestions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "meal-plans",
                "{{mealPlanId}}",
                "diet-suggestions"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Upload",
      "item": [
        {
          "name": "Upload Recipe Image",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/upload/recipe-image",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "upload",
                "recipe-image"
              ]
            },
            "description": "Accepts image files only (.jpg, .jpeg, .png, .webp, .gif), max 5MB."
          }
        }
      ]
    }
  ]
}
